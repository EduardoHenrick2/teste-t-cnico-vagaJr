{
  "openapi": "3.1.1",
  "info": {
    "title": "OficinaMecanica.API | v1",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://localhost:7174"
    },
    {
      "url": "http://localhost:5209"
    }
  ],
  "paths": {
    "/api/Orcamento": {
      "post": {
        "tags": [
          "Orcamento"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OrcamentoRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/OrcamentoRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/OrcamentoRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "OrcamentoItemRequest": {
        "type": "object",
        "properties": {
          "descricao": {
            "type": "string"
          },
          "quantidade": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "valorUnitario": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "type": [
              "number",
              "string"
            ],
            "format": "double"
          }
        }
      },
      "OrcamentoRequest": {
        "type": "object",
        "properties": {
          "clienteId": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "veiculoId": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "itens": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OrcamentoItemRequest"
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Orcamento"
    }
  ]
}